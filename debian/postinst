#!/bin/sh
set -e

# 将当前登录的桌面用户加入 input 组，以便 evdev 可读取键盘设备。
# 用户需要注销并重新登录后权限生效。
add_logged_in_users_to_input_group() {
    if ! command -v loginctl >/dev/null 2>&1; then
        return
    fi
    seat_sessions=$(loginctl show-seat seat0 -p Sessions --value 2>/dev/null || true)
    if [ -z "$seat_sessions" ]; then
        return
    fi
    for session in $seat_sessions; do
        user=$(loginctl show-session "$session" -p Name --value 2>/dev/null || true)
        if [ -n "$user" ] && id -u "$user" >/dev/null 2>&1; then
            if ! id -nG "$user" | tr ' ' '\n' | grep -qx input; then
                usermod -aG input "$user" || true
            fi
        fi
    done
}

#DEBHELPER#

# 刷新桌面数据库与图标缓存
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ]; then
    add_logged_in_users_to_input_group
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database -q /usr/share/applications || true
    fi
    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor || true
    fi
fi

exit 0
